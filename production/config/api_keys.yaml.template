# API Keys Configuration
# ======================
# Copy this file to api_keys.yaml and fill in your keys
# IMPORTANT: Never commit api_keys.yaml to git!

# Nasdaq Data Link (formerly Quandl)
# Sign up at: https://data.nasdaq.com/sign-up
nasdaq_data_link:
  api_key: YOUR_API_KEY_HERE

# Alternative: set environment variable
# export NASDAQ_DATA_LINK_API_KEY=your_key
# or on Windows:
# set NASDAQ_DATA_LINK_API_KEY=your_key
